{
  "name": "vscode-book-reader",
  "displayName": "book reader",
  "description": "Support reading epub、mobi、azw3、pdf、fk8、fb2、cbz files.支持在vscode中阅读epub、mobi、azw3、pdf、fk8、fb2、cbz电子书。",
  "publisher": "lindacong",
  "version": "1.3.4",
  "icon": "renderer/public/logo.png",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/jinhuan138/vscode-book-reader.git",
    "type": "git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "keywords": [
    "reader",
    "ebooks",
    "epub",
    "mobi",
    "pdf",
    "azw3",
    "fk8",
    "cbz",
    "fb2"
  ],
  "homepage": "https://jinhuan138.github.io/vscode-book-reader/",
  "bugs": "https://github.com/jinhuan138/vscode-book-reader/issues",
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "book-reader.openFile",
        "title": "book reader"
      },
      {
        "command": "book-reader.openBook",
        "title": "book reader"
      },
      {
        "command": "book-reader.selectBookFolder",
        "title": "select book folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "book-reader.openBookInSidebar",
        "title": "Open in Sidebar",
        "icon": "$(open-preview)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bookReader",
          "title": "book reader",
          "icon": "renderer/public/icon.svg"
        }
      ]
    },
    "views": {
      "bookReader": [
        {
          "id": "bookReaderList",
          "name": "book list",
          "icon": "$(home)"
        },
        {
          "id": "bookReaderSidebar",
          "name": "reader sidebar",
          "icon": "$(book)",
          "type": "webview"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "book-reader.openFile",
        "displayName": "book reader",
        "selector": [
          {
            "filenamePattern": "*.epub"
          },
          {
            "filenamePattern": "*.mobi"
          },
          {
            "filenamePattern": "*.fk8"
          },
          {
            "filenamePattern": "*.azw3"
          },
          {
            "filenamePattern": "*.fb2"
          },
          {
            "filenamePattern": "*.cbz"
          },
          {
            "filenamePattern": "*.pdf"
          }
        ]
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "book-reader.selectBookFolder",
          "when": "view == bookReaderList",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "book-reader.openBookInSidebar",
          "when": "view == bookReaderList && viewItem == 'bookItem'",
          "group": "inline@1"
        }
      ]
    },
    "configuration": {
      "title": "Book Reader",
      "properties": {
        "book-reader.bookFolderPath": {
          "type": "string",
          "default": "",
          "description": "Path to the folder containing books"
        }
      }
    }
  },
  "scripts": {
    "dev": "pnpm -F ./renderer dev",
    "build": "pnpm -F ./renderer build",
    "preview": "pnpm -F ./renderer preview",
    "vscode:prepublish": "pnpm compile",
    "package": "pnpm vsce package",
    "compile": "node esbuild.js",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm compile && pnpm lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~18.19.130",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/test-cli": "^0.0.8",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "bing-translate-api": "^4.2.0"
  },
  "vsce": {
    "dependencies": false,
    "useYarn": false
  },
  "packageManager": "pnpm@9.6.0"
}